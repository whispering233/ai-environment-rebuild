# AI Environment Rebuild - 本地配置模板
# 复制此文件为 local/config.local.yaml 并按需填写

# ── Agent API Keys ──
# Claude Code
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Codex CLI (OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# ── Runtime Versions (optional) ──
NODE_VERSION=22
PYTHON_VERSION=3.12
GO_VERSION=1.22
